# HỆ THỐNG TRÙM CUỐI (ALONG CORE)
# ========================================================
class AlongCoreBoss:
    def __init__(self):
        self.rect = pygame.Rect(4400, HEIGHT - 290, 180, 250)
        self.max_hp = 1050
        self.hp = 1050
        self.active = False 
        
        self.last_action_time = 0
        self.action_cooldown = 2200
        self.current_pattern = 0 
        
        self.laser_charging = False
        self.laser_charge_start = 0
        self.laser_active = False
        self.laser_active_start = 0
        self.laser_rect = pygame.Rect(0, 0, 0, 0)

    def update(self, enemy_bullets_list, enemy_list):
        if not self.active:
            if player.rect.x > 3800:
                self.active = True
                pygame.mixer.music.stop() 
            return
            
        if self.hp <= 0: return

        current_time = pygame.time.get_ticks()
        
        if self.laser_charging:
            if current_time - self.laser_charge_start > 1200: 
                self.laser_charging = False
                self.laser_active = True
                self.laser_active_start = current_time
                trigger_shake(30, 12)
                if snd_bomb_exp: snd_bomb_exp.play()
                self.laser_rect = pygame.Rect(camera_x, self.rect.y + 110, self.rect.x, 50)
        
        if self.laser_active:
            if current_time - self.laser_active_start > 1000: 
                self.laser_active = False
            else:
                if player.rect.colliderect(self.laser_rect):
                    player.take_damage(8)

        if current_time - self.last_action_time > self.action_cooldown:
            if not self.laser_charging and not self.laser_active:
                self.current_pattern = random.choice([0, 1, 2])
                self.last_action_time = current_time
                
                if self.current_pattern == 0:
                    for angle in [-4, -2, 0, 2, 4]:
                        enemy_bullets_list.append(EnemyBullet(self.rect.left, self.rect.y + 60, speed_x=-10, speed_y=angle))
                    if snd_shoot: snd_shoot.play()
                    
                elif self.current_pattern == 1:
                    if len(enemy_list) < max_enemies_on_screen + 3:
                        enemy_list.append(SuicideBomber(self.rect.left - 20, HEIGHT - 90))
                        enemy_list.append(generate_new_enemy_at(self.rect.left - 60, allow_shield=False))
                    if snd_bomb_drop: snd_bomb_drop.play()
                    
                elif self.current_pattern == 2:
                    self.laser_charging = True
                    self.laser_charge_start = current_time

    def draw(self, surface, offset_x=0, offset_y=0):
        bx, by = self.rect.x + offset_x, self.rect.y + offset_y
        
        pygame.draw.rect(surface, (40, 40, 45), (bx, by, 180, 250), 0, 15)
        pygame.draw.rect(surface, GRAY, (bx, by, 180, 250), 4, 15)
        
        t = pygame.time.get_ticks() // 150
        core_color = CYAN if (t % 2 == 0) else BLUE
        if self.laser_charging: core_color = RED if (t % 2 == 0) else ORANGE
        pygame.draw.rect(surface, core_color, (bx + 20, by + 30, 140, 60), 0, 8)
        
        pygame.draw.rect(surface, GRAY, (bx - 40, by + 110, 40, 50), 0, 4)
        pygame.draw.rect(surface, BLACK, (bx - 40, by + 120, 15, 30))
        
        if self.laser_charging:
            pygame.draw.circle(surface, RED, (bx - 40, by + 135), random.randint(10, 25))
        if self.laser_active and self.hp > 0: # Chỉ vẽ tia laser khi boss còn sống
            laser_screen_left = camera_x + offset_x
            pygame.draw.rect(surface, CYAN, (laser_screen_left, by + 110, bx - laser_screen_left, 50))
            pygame.draw.rect(surface, WHITE, (laser_screen_left, by + 120, bx - laser_screen_left, 30))

        if self.active and self.hp > 0:
            boss_bar_w, boss_bar_h = 400, 22
            bbx, bby = WIDTH - 430, 110
            surface.blit(GAME_FONT.render("ALONG CORE - BOSS CYBORG", True, WHITE), (bbx, bby - 25))
            pygame.draw.rect(surface, RED, (bbx, bby, boss_bar_w, boss_bar_h))
            pygame.draw.rect(surface, GREEN, (bbx, bby, int((self.hp / self.max_hp) * boss_bar_w), boss_bar_h))
            pygame.draw.rect(surface, WHITE, (bbx, bby, boss_bar_w, boss_bar_h), 2)

# ========================================================
# HỆ THỐNG ĐIỀU PHỐI QUÁI MAP
# ========================================================
def generate_new_enemy_at(fixed_x, allow_shield=True):
    r = random.random()
    if r < 0.3 and allow_shield: return ShieldSniper(fixed_x, HEIGHT - 90)
    elif r < 0.6: return SuicideBomber(fixed_x, HEIGHT - 90)
    elif r < 0.8: return SniperEnemy(fixed_x, HEIGHT - 90)
    return Enemy(fixed_x, HEIGHT - 90)

def create_initial_map_enemies(amount):
    enemy_list = []
    for i in range(amount):
        spawn_x = 600 + (i * random.randint(250, 450))
        if spawn_x < 3700: 
            enemy_list.append(generate_new_enemy_at(spawn_x))
    return enemy_list

def draw_hud(surface, player, boss_obj, game_cleared):
    wp_name = {"NORMAL": "DAN THUONG", "M4A1": "M4A1 (SAY LIEN THANH)", "SHOTGUN": "SHOTGUN XUYEN GIAP"}
    
    score_str = f"DIEM (TIEN): {player.score:05d}   [MAP: {player.rect.x}/{MAP_WIDTH}]   [VU KHI: {wp_name[player.weapon]}]"
    pygame.draw.rect(surface, BLACK, (15, 8, 750, 26))
    surface.blit(GAME_FONT.render(score_str, True, WHITE), (20, 10))

    BAR_X, BAR_Y, BAR_LENGTH, BAR_HEIGHT = 20, 40, 220, 20
    pygame.draw.rect(surface, RED, (BAR_X, BAR_Y, BAR_LENGTH, BAR_HEIGHT)) 
    pygame.draw.rect(surface, GREEN, (BAR_X, BAR_Y, int((player.hp / player.max_hp) * BAR_LENGTH), BAR_HEIGHT)) 
    pygame.draw.rect(surface, WHITE, (BAR_X, BAR_Y, BAR_LENGTH, BAR_HEIGHT), 2) 
    surface.blit(GAME_FONT.render(f"HP {player.hp}/{player.max_hp}", True, WHITE), (BAR_X + BAR_LENGTH + 10, BAR_Y + 2))

    lives_str = f"REST: {player.lives}   BOMBS: {player.bombs_left}/30   [A/D]: DI CHUYEN CUON MAN . TIEN VE CUOI MAP GAP BOSS"
    surface.blit(GAME_FONT.render(lives_str, True, YELLOW), (20, 70))
    
    # HIỂN THỊ MÀN HÌNH CHIẾN THẮNG KHI BOSS CHẾT
    if game_cleared:
        win_lbl = TITLE_FONT.render("MISSION ACCOMPLISHED!", True, GREEN)
        sub_lbl = MENU_FONT.render("Nhan phim [ESC] hoac o cua so de thoat game", True, WHITE)
        surface.blit(win_lbl, (WIDTH//2 - win_lbl.get_width()//2, HEIGHT//2 - 60))
        surface.blit(sub_lbl, (WIDTH//2 - sub_lbl.get_width()//2, HEIGHT//2 + 30))

# ========================================================
# HỆ THỐNG MÀN HÌNH CHỌN MENU BAN ĐẦU
# ========================================================
def show_main_menu():
    global current_difficulty, max_enemies_on_screen
    menu_running, current_screen, selected_option = True, "MAIN", 0
    main_options, diff_options = ["START GAME", "EXIT"], ["EASY (2 ENEMIES)", "NORMAL (5 ENEMIES)", "HARD (7 ENEMIES)", "CRAZY (10 ENEMIES)"]
    main_rects = [pygame.Rect(WIDTH//2 - 170, HEIGHT//2 - 20, 340, 50), pygame.Rect(WIDTH//2 - 170, HEIGHT//2 + 50, 340, 50)]
    diff_rects = [pygame.Rect(WIDTH//2 - 220, HEIGHT//2 - 60, 440, 45), pygame.Rect(WIDTH//2 - 220, HEIGHT//2 - 10, 440, 45), pygame.Rect(WIDTH//2 - 220, HEIGHT//2 + 40, 440, 45), pygame.Rect(WIDTH//2 - 220, HEIGHT//2 + 90, 440, 45)]

    while menu_running:
        mouse_pos = pygame.mouse.get_pos()
        options = main_options if current_screen == "MAIN" else diff_options
        btn_rects = main_rects if current_screen == "MAIN" else diff_rects
        
        for event in pygame.event.get():
            if event.type == pygame.QUIT: pygame.quit(); os._exit(0)
            if event.type == pygame.KEYDOWN:
                if event.key in [pygame.K_UP, pygame.K_w]: 
                    selected_option = (selected_option - 1) % len(options)
                    if snd_jump: snd_jump.play()
                elif event.key in [pygame.K_DOWN, pygame.K_s]: 
                    selected_option = (selected_option + 1) % len(options)
                    if snd_jump: snd_jump.play()
                elif event.key == pygame.K_ESCAPE and current_screen == "DIFFICULTY": current_screen = "MAIN"; selected_option = 0
                elif event.key in [pygame.K_RETURN, pygame.K_SPACE]:
                    if current_screen == "MAIN":
                        if selected_option == 0: current_screen = "DIFFICULTY"; selected_option = 1
                        else: pygame.quit(); os._exit(0)
                    elif current_screen == "DIFFICULTY":
                        mapping = {0: ("EASY", 2), 1: ("NORMAL", 5), 2: ("HARD", 7), 3: ("CRAZY", 10)}
                        current_difficulty, max_enemies_on_screen = mapping[selected_option]
                        menu_running = False
                        
        for idx, rect in enumerate(btn_rects):
            if rect.collidepoint(mouse_pos): selected_option = idx

        screen.blit(large_background_image, (-camera_x, 0))
        screen.blit(large_ground_texture, (-camera_x, HEIGHT - 40))
        title_main = TITLE_FONT.render("MINI CONTRA", True, RED)
        screen.blit(title_main, (WIDTH // 2 - title_main.get_width() // 2, HEIGHT // 2 - 170))

        if current_screen == "MAIN":
            sub_text = GAME_FONT.render("[ FIX ERROR UPDATE ]", True, YELLOW)
            screen.blit(sub_text, (WIDTH // 2 - sub_text.get_width() // 2, HEIGHT // 2 - 80))
            for idx, option in enumerate(options):
                color = YELLOW if idx == selected_option else WHITE
                opt_text = MENU_FONT.render(option, True, color)
                bx, by = btn_rects[idx].centerx - opt_text.get_width() // 2, btn_rects[idx].centery - opt_text.get_height() // 2
                if idx == selected_option: screen.blit(MENU_FONT.render(">>", True, RED), (bx - 45, by))
                screen.blit(opt_text, (bx, by))
        elif current_screen == "DIFFICULTY":
            screen.blit(GAME_FONT.render("SELECT DIFFICULTY MODE", True, WHITE), (WIDTH // 2 - 120, HEIGHT // 2 - 110))
            diff_colors = [GREEN, YELLOW, ORANGE, PURPLE]
            for idx, option in enumerate(options):
                color = diff_colors[idx] if idx == selected_option else GRAY
                opt_text = MENU_FONT.render(option, True, color)
                bx, by = btn_rects[idx].centerx - opt_text.get_width() // 2, btn_rects[idx].centery - opt_text.get_height() // 2
                if idx == selected_option: screen.blit(MENU_FONT.render(">", True, WHITE), (bx - 30, by))
                screen.blit(opt_text, (bx, by))

        pygame.display.flip()
        clock.tick(60)

# ========================================================
# HỆ THỐNG CỬA HÀNG VŨ KHÍ (PHÍM B)
# ========================================================
def open_shop_menu(player):
    shop_running = True
    selected_item = 0
    items = [
        {"name": "Revival Potion (+50 HP)", "cost": 100, "desc": "Hoi phuc ngay 50 diem sinh luc"},
        {"name": "M4A1 GUN (Automatic Rifle)", "cost": 300, "desc": "Giu chat SPACE de tu dong xa dan cuc nhanh"},
        {"name": "Shotgun shell piercing armor", "cost": 500, "desc": "Ban chum 3 tia dan Xuyen qua tat ca muc tieu"}
    ]
    overlay = pygame.Surface((WIDTH, HEIGHT))
    overlay.set_alpha(200)
    overlay.fill(BLACK)

    while shop_running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT: pygame.quit(); os._exit(0)
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_b or event.key == pygame.K_ESCAPE:
                    shop_running = False 
                elif event.key in [pygame.K_UP, pygame.K_w]:
                    selected_item = (selected_item - 1) % len(items)
                    if snd_jump: snd_jump.play()
                elif event.key in [pygame.K_DOWN, pygame.K_s]:
                    selected_item = (selected_item + 1) % len(items)
                    if snd_jump: snd_jump.play()
                elif event.key in [pygame.K_RETURN, pygame.K_SPACE]:
                    item = items[selected_item]
                    if player.score >= item["cost"]:
                        player.score -= item["cost"] 
                        if selected_item == 0: player.hp = min(player.max_hp, player.hp + 50)
                        elif selected_item == 1: player.weapon = "M4A1"
                        elif selected_item == 2: player.weapon = "SHOTGUN"
                        if snd_bomb_exp: snd_bomb_exp.play() 
                    else:
                        if snd_player_hit: snd_player_hit.play() 

        screen.blit(overlay, (0, 0))
        shop_title = TITLE_FONT.render("WEAPONS STORE", True, YELLOW)
        screen.blit(shop_title, (WIDTH//2 - shop_title.get_width()//2, 60))
        
        money_str = f"YOUR MONEY: {player.score} SCORE"
        screen.blit(MENU_FONT.render(money_str, True, GREEN), (WIDTH//2 - 180, 160))

        for idx, item in enumerate(items):
            is_selected = (idx == selected_item)
            text_color = CYAN if is_selected else WHITE
            item_text = f"{item['name']} - Gia: {item['cost']} Diem"
            item_render = MENU_FONT.render(item_text, True, text_color)
            ix, iy = WIDTH//2 - 350, 240 + idx * 80
            if is_selected:
                pygame.draw.rect(screen, (30, 30, 30), (ix - 20, iy - 5, 750, 70), 0, 8)
                pygame.draw.rect(screen, CYAN, (ix - 20, iy - 5, 750, 70), 2, 8)
                screen.blit(MENU_FONT.render(">", True, CYAN), (ix - 45, iy))
                desc_render = GAME_FONT.render(item["desc"], True, YELLOW)
                screen.blit(desc_render, (ix, iy + 40))
            screen.blit(item_render, (ix, iy))

        help_shop = "ARROW KEYS TO SELECT . ENTER TO BUY . PRESS [B] OR [ESC] TO RETURN"
        screen.blit(GAME_FONT.render(help_shop, True, GRAY), (WIDTH//2 - 380, HEIGHT - 80))
        pygame.display.flip()
        clock.tick(60)

# Khởi chạy menu 
show_main_menu()

# ========================================================
# KHỞI TẠO GAMEPLAY CHÍNH
# ========================================================
player = Player()
boss = AlongCoreBoss()
player_bullets, enemy_bullets, bombs, explosions, dust_particles = [], [], [], [], []
enemies = create_initial_map_enemies(max_enemies_on_screen * 3)

game_cleared = False # Biến cờ kiểm soát trạng thái phá đảo game
running = True

while running:
    current_time = pygame.time.get_ticks()

    for event in pygame.event.get():
        if event.type == pygame.QUIT: running = False
        if event.type == pygame.KEYDOWN:
            # Nếu đã phá đảo, cho phép nhấn ESC để thoát nhanh ra ngoài
            if game_cleared and event.key == pygame.K_ESCAPE:
                running = False
                
            if not game_cleared: # Chỉ cho phép nhận phím điều khiển khi chưa thắng
                if event.key in [pygame.K_UP, pygame.K_w]: player.jump()
                if event.key == pygame.K_SPACE and player.weapon != "M4A1":
                    bullet_x = player.rect.right if player.facing_right else player.rect.left
                    if player.weapon == "NORMAL":
                        player_bullets.append(PlayerBullet(bullet_x, player.rect.y + 26, player.facing_right))
                    elif player.weapon == "SHOTGUN":
                        player_bullets.append(PlayerBullet(bullet_x, player.rect.y + 26, player.facing_right, angle_y=0, is_piercing=True))
                        player_bullets.append(PlayerBullet(bullet_x, player.rect.y + 26, player.facing_right, angle_y=-3, is_piercing=True))
                        player_bullets.append(PlayerBullet(bullet_x, player.rect.y + 26, player.facing_right, angle_y=3, is_piercing=True))
                    if snd_shoot: snd_shoot.play()
                if event.key == pygame.K_e and player.bombs_left > 0:
                    bomb_x = player.rect.right if player.facing_right else player.rect.left
                    bombs.append(Bomb(bomb_x, player.rect.y + 10, player.facing_right))
                    player.bombs_left -= 1
                    if snd_bomb_drop: snd_bomb_drop.play()
                if event.key == pygame.K_b:
                    open_shop_menu(player)

    # NẾU GAME CHƯA KẾT THÚC -> TIẾN HÀNH XỬ LÝ LOGIC VẬT LÝ GAMEPLAY
    if not game_cleared:
        # Tự động quét kiểm tra xem HP Boss đã về 0 chưa để kích hoạt Phá Đảo
        if boss.active and boss.hp <= 0:
            game_cleared = True
            pygame.mixer.music.stop() # Tắt nhạc nền khốc liệt
            # Xóa sạch toàn bộ đạn và quái lính để sàn đấu yên bình
            enemies.clear()
            enemy_bullets.clear()
            player_bullets.clear()
            bombs.clear()
            continue

        # ĐẶC TÍNH SÚNG M4A1
        keys = pygame.key.get_pressed()
        if keys[pygame.K_SPACE] and player.weapon == "M4A1":
            if current_time - player.last_m4a1_shot > 230: 
                bullet_x = player.rect.right if player.facing_right else player.rect.left
                player_bullets.append(PlayerBullet(bullet_x, player.rect.y + 26, player.facing_right))
                if snd_shoot: snd_shoot.play()
                player.last_m4a1_shot = current_time

        player.move(keys, dust_particles, boss.active) 
        player.apply_gravity(dust_particles) 

        # VẬT LÝ CHẶN KHÔNG CHO ĐI XUYÊN QUA QUÁI CẦM KHIÊN
        for enemy in enemies:
            if enemy.type == "SHIELD":
                shield_wall = pygame.Rect(enemy.rect.x - 15, enemy.rect.y, enemy.rect.width + 15, enemy.rect.height)
                if player.rect.colliderect(shield_wall):
                    if player.facing_right and player.rect.centerx < enemy.rect.left:
                        player.rect.right = shield_wall.left
                    elif not player.facing_right and player.rect.centerx > enemy.rect.right:
                        player.rect.left = shield_wall.right

        # CẬP NHẬT CAMERA CUỘN MÀN HÌNH
        if not boss.active:
            camera_x = player.rect.x - WIDTH // 3
            if camera_x < 0: camera_x = 0
            if camera_x > MAP_WIDTH - WIDTH: camera_x = MAP_WIDTH - WIDTH
        else:
            camera_x = MAP_WIDTH - WIDTH

        # Cập nhật đạn ta
        for bullet in player_bullets[:]:
            bullet.update()
            if bullet.rect.left > MAP_WIDTH or bullet.rect.right < 0 or bullet.rect.bottom < 0 or bullet.rect.top > HEIGHT:
                player_bullets.remove(bullet)

        # Cập nhật Bom nổ công phá diện rộng
        for bomb in bombs[:]:
            bomb.update(dust_particles)
            if bomb.is_exploded:
                explosions.append(Explosion(int(bomb.x), int(bomb.y), is_bomb_explosion=True))
                if snd_bomb_exp: snd_bomb_exp.play()  
                trigger_shake(15, 8)
                
                for enemy in enemies[:]:
                    if abs(bomb.x - enemy.rect.centerx) < 140:  
                        enemy.hp -= 3.5   
                        if enemy.hp <= 0:
                            explosions.append(Explosion(enemy.rect.centerx, enemy.rect.centery))
                            if snd_explosion: snd_explosion.play()  
                            if enemy in enemies: enemies.remove(enemy)
                            player.score += 100
                
                if boss.active and boss.hp > 0:
                    if abs(bomb.x - boss.rect.centerx) < 180:
                        boss.hp -= 15
                bombs.remove(bomb)

        boss.update(enemy_bullets, enemies)
        for enemy in enemies: enemy.update(enemy_bullets, player)

        # Cập nhật đạn địch
        for e_bullet in enemy_bullets[:]:
            e_bullet.update()
            if e_bullet.rect.right < 0 or e_bullet.rect.left > MAP_WIDTH: 
                enemy_bullets.remove(e_bullet)

        # VA CHẠM ĐẠN TA TRÚNG KẺ ĐỊCH / TRÚNG BOSS
        for bullet in player_bullets[:]:
            if boss.active and boss.hp > 0 and bullet.rect.colliderect(boss.rect):
                if bullet in player_bullets: player_bullets.remove(bullet)
                boss.hp -= 1.5 if player.weapon == "SHOTGUN" else 1.0
                continue
                
            for enemy in enemies[:]:
                if bullet.rect.colliderect(enemy.rect):
                    if bullet.is_piercing:
                        if enemy not in bullet.hit_enemies:
                            bullet.hit_enemies.append(enemy)
                            enemy.hp -= 1.5 
                    else:
                        if bullet in player_bullets: player_bullets.remove(bullet)
                        enemy.hp -= 1
                    
                    if enemy.hp <= 0:
                        explosions.append(Explosion(enemy.rect.centerx, enemy.rect.centery))
                        if snd_explosion: snd_explosion.play()  
                        if enemy in enemies: enemies.remove(enemy)
                        player.score += 100

        # VA CHẠM CẬN CHIẾN: QUÁI ÔM BOM TỰ NỔ
        for enemy in enemies[:]:
            if player.rect.colliderect(enemy.rect):
                if enemy.type == "BOMBER":
                    explosions.append(Explosion(enemy.rect.centerx, enemy.rect.centery, is_bomb_explosion=True))
                    if snd_bomb_exp: snd_bomb_exp.play()
                    trigger_shake(15, 8)
                    player.take_damage(40) 
                    if enemy in enemies: enemies.remove(enemy)
                else:
                    player.take_damage(5)

        # Đạn địch bắn trúng người chơi
        for e_bullet in enemy_bullets[:]:
            if player.rect.colliderect(e_bullet.rect):
                player.take_damage(e_bullet.damage)
                if e_bullet in enemy_bullets: enemy_bullets.remove(e_bullet)

        # Triệt tiêu đạn lẫn nhau
        for p_bullet in player_bullets[:]:
            for e_bullet in enemy_bullets[:]:
                if p_bullet.rect.colliderect(e_bullet.rect):
                    mid_x = (p_bullet.rect.x + e_bullet.rect.x) // 2
                    mid_y = (p_bullet.rect.y + e_bullet.rect.y) // 2
                    explosions.append(Explosion(mid_x, mid_y))
                    if snd_explosion: snd_explosion.play()  
                    if p_bullet in player_bullets: player_bullets.remove(p_bullet)
                    if e_bullet in enemy_bullets: enemy_bullets.remove(e_bullet)

        # Đạn địch dính vòng bom nổ sẽ biến mất
        for e_bullet in enemy_bullets[:]:
            for exp in explosions:
                if exp.is_bomb_explosion:
                    if ((e_bullet.rect.centerx - exp.x)**2 + (e_bullet.rect.centery - exp.y)**2)**0.5 <= exp.radius:
                        if e_bullet in enemy_bullets: enemy_bullets.remove(e_bullet)
                        break  

        # Xử lý Hết HP / Hồi sinh / Game Over
        if player.hp <= 0:
            player.lives -= 1 
            if player.lives > 0:
                player.hp = 200
                player.rect.x = camera_x + 50 
                player.bombs_left = 30  
                player.weapon = "NORMAL" 
                player_bullets.clear(); enemy_bullets.clear(); bombs.clear(); explosions.clear(); dust_particles.clear()
            else:
                pygame.mixer.music.stop()
                if snd_game_over: snd_game_over.play()
                pygame.time.delay(10)  
                print(f"GAME OVER! Tong so diem kiem duoc: {player.score}")
                running = False 

    # Cập nhật hiệu ứng vụ nổ và khói bụi (Vẫn chạy kể cả khi thắng để nhìn mượt mà)
    for exp in explosions[:]:
        exp.update()
        if exp.is_dead: explosions.remove(exp)
    for dust in dust_particles[:]:
        dust.update()
        if dust.is_dead: dust_particles.remove(dust)

    # Rung màn hình
    current_offset_x, current_offset_y = -camera_x, 0
    if shake_duration > 0:
        current_offset_x += random.randint(-shake_intensity, shake_intensity)
        current_offset_y += random.randint(-shake_intensity, shake_intensity)
        shake_duration -= 1 

    # ========================================================
    # RENDER ĐỒ HỌA
    # ========================================================
    screen.blit(large_background_image, (current_offset_x, current_offset_y))
    screen.blit(large_ground_texture, (current_offset_x, HEIGHT - 40 + current_offset_y))
    
    for dust in dust_particles: dust.draw(screen, current_offset_x, current_offset_y)
    player.draw(screen, current_offset_x, current_offset_y)
    
    for enemy in enemies: enemy.draw(screen, current_offset_x, current_offset_y)
    boss.draw(screen, current_offset_x, current_offset_y)
    
    for bullet in player_bullets: bullet.draw(screen, current_offset_x, current_offset_y)
    for bomb in bombs: bomb.draw(screen, current_offset_x, current_offset_y)
    for e_bullet in enemy_bullets: e_bullet.draw(screen, current_offset_x, current_offset_y)
    for exp in explosions: exp.draw(screen, current_offset_x, current_offset_y)
    
    # Giao diện tĩnh HUD đè lên trên cùng
    draw_hud(screen, player, boss, game_cleared)
    
    pygame.display.flip()
    clock.tick(60)

pygame.quit()
os._exit(0)




