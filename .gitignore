# ========================================================
# HỆ THỐNG ĐỒ HỌA NỀN BẢN ĐỒ LỚN (LARGE MAP BACKGROUND)
# ========================================================
def create_large_jungle_background():
    bg = pygame.Surface((MAP_WIDTH, HEIGHT))
    bg.fill((10, 15, 30)) 
    
    pygame.draw.circle(bg, (220, 225, 230), (700, 120), 25)
    pygame.draw.circle(bg, (10, 15, 30), (712, 112), 23)
    
    for i in range(0, MAP_WIDTH, 120):
        h = random.randint(180, 260)
        pygame.draw.ellipse(bg, (15, 25, 25), (i - 20, HEIGHT - h, 200, h))
    for i in range(0, MAP_WIDTH, 80):
        h = random.randint(110, 150)
        pygame.draw.ellipse(bg, (20, 40, 30), (i - 15, HEIGHT - h, 140, h))
    return bg

def create_large_ground_texture():
    ground_surf = pygame.Surface((MAP_WIDTH, 40))
    ground_surf.fill((105, 55, 40))
    for x in range(0, MAP_WIDTH, 30):
        for y in range(0, 40, 15):
            pygame.draw.rect(ground_surf, (55, 25, 15), (x, y, 30, 15), 1)
            if random.random() > 0.7:
                pygame.draw.rect(ground_surf, (45, 95, 45), (x + 2, y + 2, 8, 3))
    return ground_surf

large_background_image = create_large_jungle_background()
large_ground_texture = create_large_ground_texture()

# ========================================================
# HỆ THỐNG ANIMATION BẰNG CODE
# ========================================================
def create_character_frames(main_color, hat_color):
    frames = {'idle': [], 'run': [], 'jump': []}
    w, h = 40, 50
    def get_surface(): return pygame.Surface((w, h), pygame.SRCALPHA)
    SKIN, GUN, LEG_COLOR = (255, 204, 153), (150, 150, 150), BLACK

    # IDLE
    surf = get_surface()
    pygame.draw.circle(surf, SKIN, (20, 12), 10)            
    pygame.draw.rect(surf, hat_color, (10, 2, 20, 6))       
    pygame.draw.rect(surf, BLACK, (22, 8, 4, 4))            
    pygame.draw.rect(surf, main_color, (12, 22, 16, 18))    
    pygame.draw.rect(surf, LEG_COLOR, (12, 40, 7, 10))      
    pygame.draw.rect(surf, LEG_COLOR, (21, 40, 7, 10))      
    pygame.draw.rect(surf, GUN, (20, 26, 18, 6))            
    frames['idle'].append(surf)

    # RUN
    run_cycle = [(-4, 4), (0, 0), (4, -4), (0, 0)]
    for lx, rx in run_cycle:
        surf = get_surface()
        bob = 2 if lx == 0 else 0  
        pygame.draw.circle(surf, SKIN, (20, 12 + bob), 10)
        pygame.draw.rect(surf, hat_color, (10, 2 + bob, 20, 6))
        pygame.draw.rect(surf, BLACK, (22, 8 + bob, 4, 4))
        pygame.draw.rect(surf, main_color, (12, 22 + bob, 16, 18))
        pygame.draw.rect(surf, LEG_COLOR, (13 + lx, 40 + (bob if lx <= 0 else -2), 7, 10))
        pygame.draw.rect(surf, LEG_COLOR, (20 + rx, 40 + (bob if rx <= 0 else -2), 7, 10))
        pygame.draw.rect(surf, GUN, (20, 26 + bob, 18, 6))
        frames['run'].append(surf)

    # JUMP
    surf = get_surface()
    pygame.draw.circle(surf, SKIN, (20, 12), 10)
    pygame.draw.rect(surf, hat_color, (10, 2, 20, 6))
    pygame.draw.rect(surf, BLACK, (22, 8, 4, 4))
    pygame.draw.rect(surf, main_color, (12, 22, 16, 18))
    pygame.draw.rect(surf, LEG_COLOR, (11, 37, 8, 8))       
    pygame.draw.rect(surf, LEG_COLOR, (21, 37, 8, 8))       
    pygame.draw.rect(surf, GUN, (20, 24, 18, 6))
    frames['jump'].append(surf)
    return frames

class DustParticle:
    def __init__(self, x, y, vel_x):
        self.x, self.y = x, y
        self.vel_x = vel_x + random.uniform(-1.5, 1.5)
        self.vel_y = random.uniform(-2.0, -0.5) 
        self.radius = random.randint(3, 6)      
        self.alpha = 200                        
        self.fade_speed = random.randint(8, 15) 
        self.is_dead = False

    def update(self):
        self.x += self.vel_x
        self.y += self.vel_y
        self.alpha -= self.fade_speed
        if self.alpha <= 0: self.is_dead = True

    def draw(self, surface, offset_x=0, offset_y=0):
        if not self.is_dead:
            dust_surf = pygame.Surface((self.radius * 2, self.radius * 2), pygame.SRCALPHA)
            pygame.draw.circle(dust_surf, (DUST_COLOR[0], DUST_COLOR[1], DUST_COLOR[2], self.alpha), (self.radius, self.radius), self.radius)
            surface.blit(dust_surf, (int(self.x - self.radius) + offset_x, int(self.y - self.radius) + offset_y))

class Explosion:
    def __init__(self, x, y, is_bomb_explosion=False):
        self.x, self.y = x, y
        self.is_bomb_explosion = is_bomb_explosion
        self.radius = 5 if not is_bomb_explosion else 15
        self.max_radius = 20 if not is_bomb_explosion else 100
        self.speed = 2 if not is_bomb_explosion else 6
        self.is_dead = False
        self.sparks = []
        num_sparks = 8 if not is_bomb_explosion else 25
        for _ in range(num_sparks):
            self.sparks.append({
                'x': float(x), 'y': float(y),
                'vx': random.uniform(-4, 4) if not is_bomb_explosion else random.uniform(-10, 10),
                'vy': random.uniform(-4, 4) if not is_bomb_explosion else random.uniform(-12, 4),
                'color': random.choice([YELLOW, RED, ORANGE]),
                'size': random.randint(2, 5) if not is_bomb_explosion else random.randint(3, 8)
            })

    def update(self):
        self.radius += self.speed
        if self.radius >= self.max_radius: self.is_dead = True
        for spark in self.sparks:
            spark['x'] += spark['vx']
            spark['y'] += spark['vy']
            if self.is_bomb_explosion: spark['vy'] += 0.3  

    def draw(self, surface, offset_x=0, offset_y=0):
        if self.is_dead: return
        cx, cy = self.x + offset_x, self.y + offset_y
        alpha = max(0, int(255 * (1 - (self.radius / self.max_radius))))
        exp_surf = pygame.Surface((self.radius * 2, self.radius * 2), pygame.SRCALPHA)
        color = (255, 140, 0, alpha) if self.is_bomb_explosion else (255, 69, 0, alpha)
        pygame.draw.circle(exp_surf, color, (self.radius, self.radius), self.radius)
        surface.blit(exp_surf, (int(cx - self.radius), int(cy - self.radius)))
        for spark in self.sparks:
            pygame.draw.circle(surface, spark['color'], (int(spark['x']) + offset_x, int(spark['y']) + offset_y), spark['size'])

class Player:
    def __init__(self):
        self.rect = pygame.Rect(100, HEIGHT - 90, 40, 50)
        self.speed = 6
        self.jump_power = -11.5
        self.velocity_y = 0
        self.is_jumping = False
        self.facing_right = True
        self.frames = create_character_frames(BLUE, RED)
        self.state = 'idle'
        self.frame_index = 0
        self.animation_speed = 0.2
        
        self.max_hp = 200
        self.hp = 200
        self.lives = 3  
        self.score = 0  
        self.invincible_time = 0 
        self.bombs_left = 30 
        
        self.weapon = "NORMAL"  
        self.last_m4a1_shot = 0  

    def move(self, keys, dust_list, boss_spawned):
        moving = False
        vel_x_dust = 0
        
        min_x = camera_x
        max_x = MAP_WIDTH - 50
        
        if keys[pygame.K_LEFT] or keys[pygame.K_a]:
            if self.rect.left > min_x:
                self.rect.x -= self.speed
                self.facing_right = False
                moving, vel_x_dust = True, 2.0  
        if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
            if self.rect.right < max_x:
                self.rect.x += self.speed
                self.facing_right = True
                moving, vel_x_dust = True, -2.0 

        if self.is_jumping: self.state = 'jump'
        elif moving:
            self.state = 'run'
            if random.random() < 0.35: dust_list.append(DustParticle(self.rect.centerx, self.rect.bottom, vel_x_dust))
        else: self.state = 'idle'

    def jump(self):
        if not self.is_jumping:
            self.velocity_y = self.jump_power
            self.is_jumping = True
            if snd_jump: snd_jump.play()

    def apply_gravity(self, dust_list):
        self.velocity_y += 0.6
        self.rect.y += int(self.velocity_y)
        if self.rect.y >= HEIGHT - 90:
            if self.is_jumping and self.velocity_y > 0:
                for _ in range(6): dust_list.append(DustParticle(self.rect.centerx, HEIGHT - 40, random.uniform(-3, 3)))
            self.rect.y = HEIGHT - 90
            self.is_jumping = False
            self.velocity_y = 0

    def take_damage(self, amount):
        current_time = pygame.time.get_ticks()
        if current_time > self.invincible_time:
            self.hp -= amount
            if snd_player_hit: snd_player_hit.play()
            if self.hp < 0: self.hp = 0
            self.invincible_time = current_time + 1000 

    def draw(self, surface, offset_x=0, offset_y=0):
        current_time = pygame.time.get_ticks()
        if current_time < self.invincible_time and (current_time // 100) % 2 == 0: return
        if self.state == 'run': self.frame_index += self.animation_speed
        else: self.frame_index = 0

        frame_list = self.frames[self.state]
        current_frame = frame_list[int(self.frame_index) % len(frame_list)]
        if not self.facing_right: current_frame = pygame.transform.flip(current_frame, True, False)
        surface.blit(current_frame, self.rect.move(offset_x, offset_y))

class Bomb:
    def __init__(self, x, y, facing_right):
        self.x, self.y = float(x), float(y)
        self.vel_x = 8.0 if facing_right else -8.0
        self.vel_y, self.gravity, self.radius = -7.0, 0.4, 8
        self.rect = pygame.Rect(x - self.radius, y - self.radius, self.radius * 2, self.radius * 2)
        self.is_exploded = False

    def update(self, dust_list):
        if random.random() < 0.4: dust_list.append(DustParticle(int(self.x), int(self.y), -self.vel_x * 0.2))
        self.vel_y += self.gravity
        self.x += self.vel_x
        self.y += self.vel_y
        self.rect.x = int(self.x - self.radius)
        self.rect.y = int(self.y - self.radius)
        if self.y >= HEIGHT - 55: self.is_exploded = True

    def draw(self, surface, offset_x=0, offset_y=0):
        bx, by = int(self.x) + offset_x, int(self.y) + offset_y
        pygame.draw.circle(surface, BOMB_COLOR, (bx, by), self.radius)
        pygame.draw.circle(surface, RED, (bx, by - self.radius + 2), 2)
        pygame.draw.circle(surface, BLACK, (bx, by), self.radius, 1)

class PlayerBullet:
    def __init__(self, x, y, facing_right, angle_y=0, is_piercing=False):
        self.rect = pygame.Rect(x, y, 14 if is_piercing else 12, 6)
        self.speed_x = (15 if facing_right else -15)
        if is_piercing: self.speed_x = (17 if facing_right else -17) 
        self.speed_y = angle_y
        self.is_piercing = is_piercing  
        self.hit_enemies = []           
        self.history = []
        self.max_history = 4 

    def update(self):
        self.history.insert(0, (self.rect.x, self.rect.y))
        if len(self.history) > self.max_history: self.history.pop()
        self.rect.x += self.speed_x
        self.rect.y += self.speed_y

    def draw(self, surface, offset_x=0, offset_y=0):
        for i, pos in enumerate(self.history):
            alpha = int(180 * (1 - (i / self.max_history)))
            w = max(2, self.rect.width - (i * 2))
            h = max(2, self.rect.height - (i * 1))
            tracer_surf = pygame.Surface((w, h), pygame.SRCALPHA)
            if self.is_piercing: color = (0, 255, 255, alpha)
            else: color = (255, 165, 0, alpha) if i > 1 else (255, 255, 0, alpha)
            pygame.draw.rect(tracer_surf, color, (0, 0, w, h))
            surface.blit(tracer_surf, (pos[0] + offset_x, pos[1] + (self.rect.height - h)//2 + offset_y))

        moved_rect = self.rect.move(offset_x, offset_y)
        pygame.draw.rect(surface, WHITE if not self.is_piercing else CYAN, moved_rect) 
        pygame.draw.rect(surface, YELLOW if not self.is_piercing else BLUE, moved_rect, 1) 

class EnemyBullet:
    def __init__(self, x, y, speed_x=-8, speed_y=0, is_sniper=False):
        self.rect = pygame.Rect(x, y, 16 if is_sniper else 8, 4 if is_sniper else 8)    
        self.speed_x = speed_x
        self.speed_y = speed_y
        self.damage = 20 if is_sniper else 6
        self.color = ORANGE if is_sniper else ENEMY_BULLET_COLOR

    def update(self):
        self.rect.x += self.speed_x
        self.rect.y += self.speed_y
        
    def draw(self, surface, offset_x=0, offset_y=0): 
        pygame.draw.rect(surface, self.color, self.rect.move(offset_x, offset_y))

# ========================================================
# HỆ THỐNG KÈ ĐỊCH ĐA DẠNG
# ========================================================
class Enemy:
    def __init__(self, x, y):
        self.rect = pygame.Rect(x, y, 40, 50)
        self.speed = random.uniform(-2.5, -1.5) 
        self.shoot_cooldown = random.randint(1500, 3500)
        self.last_shot_time = pygame.time.get_ticks() + random.randint(0, 1500)
        self.frames = create_character_frames(RED, BLACK)
        self.frame_index, self.animation_speed, self.facing_right = 0, 0.15, False 
        self.max_hp, self.hp = 3, 3
        self.type = "NORMAL"

    def update(self, enemy_bullets_list, player_obj):
        self.rect.x += self.speed
        if self.rect.right < camera_x - 100:
            self.rect.x = camera_x + WIDTH + random.randint(50, 300)
            self.hp = self.max_hp
        self.frame_index = (self.frame_index + self.animation_speed) % len(self.frames['run'])
        
        current_time = pygame.time.get_ticks()
        if current_time - self.last_shot_time > self.shoot_cooldown:
            if camera_x < self.rect.x < camera_x + WIDTH: 
                enemy_bullets_list.append(EnemyBullet(self.rect.left, self.rect.y + 26, speed_x=-8))
                if snd_shoot: snd_shoot.play()  
            self.last_shot_time = current_time
            self.shoot_cooldown = random.randint(2000, 4000)

    def draw_hp_bar(self, surface, offset_x, offset_y):
        if self.hp > 0:
            bar_width, bar_height = 36, 5          
            bx, by = self.rect.x + (self.rect.width - bar_width)//2 + offset_x, self.rect.y - 10 + offset_y
            pygame.draw.rect(surface, RED, (bx, by, bar_width, bar_height))
            pygame.draw.rect(surface, YELLOW, (bx, by, int((self.hp / self.max_hp) * bar_width), bar_height))
            pygame.draw.rect(surface, BLACK, (bx, by, bar_width, bar_height), 1)

    def draw(self, surface, offset_x=0, offset_y=0):
        current_frame = self.frames['run'][int(self.frame_index)]
        if not self.facing_right: current_frame = pygame.transform.flip(current_frame, True, False)
        surface.blit(current_frame, self.rect.move(offset_x, offset_y))
        self.draw_hp_bar(surface, offset_x, offset_y)

class SniperEnemy(Enemy):
    def __init__(self, x, y):
        super().__init__(x, y)
        self.speed = random.uniform(-1.5, -1.0)                          
        self.shoot_cooldown = random.randint(3000, 5000) 
        self.frames = create_character_frames(ORANGE, GRAY)
        self.max_hp, self.hp = 4, 4
        self.type = "SNIPER"

    def update(self, enemy_bullets_list, player_obj):
        self.rect.x += self.speed
        if self.rect.right < camera_x - 100:
            self.rect.x = camera_x + WIDTH + random.randint(100, 400)
            self.hp = self.max_hp
        self.frame_index = (self.frame_index + self.animation_speed) % len(self.frames['run'])
        
        current_time = pygame.time.get_ticks()
        if current_time - self.last_shot_time > self.shoot_cooldown:
            if camera_x < self.rect.x < camera_x + WIDTH:
                enemy_bullets_list.append(EnemyBullet(self.rect.left, self.rect.y + 26, speed_x=-15, is_sniper=True))
                if snd_shoot: snd_shoot.play()  
            self.last_shot_time = current_time

class SuicideBomber(Enemy):
    def __init__(self, x, y):
        super().__init__(x, y)
        self.speed = -3.0  
        self.max_hp, self.hp = 2, 2
        self.frames = create_character_frames(YELLOW, RED)
        self.type = "BOMBER"

    def update(self, enemy_bullets_list, player_obj):
        if self.rect.x < player_obj.rect.x:
            self.speed = 3.0
            self.facing_right = True
        else:
            self.speed = -3.0
            self.facing_right = False
        self.rect.x += self.speed
        self.frame_index = (self.frame_index + 0.2) % len(self.frames['run'])

    def draw(self, surface, offset_x=0, offset_y=0):
        rx, ry = self.rect.x + offset_x, self.rect.y + offset_y
        current_frame = self.frames['run'][int(self.frame_index)]
        if not self.facing_right: current_frame = pygame.transform.flip(current_frame, True, False)
        surface.blit(current_frame, (rx, ry))
        
        t = pygame.time.get_ticks() // 100
        bomb_color = RED if t % 2 == 0 else ORANGE
        pygame.draw.circle(surface, bomb_color, (rx + (15 if self.facing_right else 25), ry + 25), 6)
        self.draw_hp_bar(surface, offset_x, offset_y)

class ShieldSniper(Enemy):
    def __init__(self, x, y):
        super().__init__(x, y)
        self.speed = 0  
        self.max_hp, self.hp = 8, 8 
        self.frames = create_character_frames(GRAY, BLACK)
        self.type = "SHIELD"
        self.shoot_cooldown = 2500
        
    def update(self, enemy_bullets_list, player_obj):
        current_time = pygame.time.get_ticks()
        if current_time - self.last_shot_time > self.shoot_cooldown:
            if camera_x < self.rect.x < camera_x + WIDTH:
                enemy_bullets_list.append(EnemyBullet(self.rect.left - 5, self.rect.y + 26, speed_x=-8))
                if snd_shoot: snd_shoot.play()
            self.last_shot_time = current_time

    def draw(self, surface, offset_x=0, offset_y=0):
        rx, ry = self.rect.x + offset_x, self.rect.y + offset_y
        current_frame = self.frames['idle'][0]
        current_frame = pygame.transform.flip(current_frame, True, False) 
        surface.blit(current_frame, (rx, ry))
        
        pygame.draw.rect(surface, GRAY, (rx - 15, ry + 10, 18, 40), 0, 4)
        pygame.draw.rect(surface, BLACK, (rx - 15, ry + 10, 18, 40), 1, 4)
        for i in range(ry + 15, ry + 45, 8):
            pygame.draw.line(surface, WHITE, (rx - 10, i), (rx - 2, i + 4), 2)
        self.draw_hp_bar(surface, offset_x, offset_y)

